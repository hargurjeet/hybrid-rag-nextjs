# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real keys

# ── Cohere (required for reranking) ──────────────────────────────────────────
CO_API_KEY=your_cohere_api_key_here

# ── LLM Backend — choose ONE ─────────────────────────────────────────────────

# Option 1: Groq (recommended — free, fast)
USE_GROQ=true
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile          # optional, this is the default

# Option 2: HuggingFace Inference API
# USE_HF_INFERENCE=true
# HF_TOKEN=your_hf_token_here
# HF_MODEL=HuggingFaceH4/zephyr-7b-beta     # optional

# Option 3: Ollama (local, no key needed)
# USE_GROQ=false
# USE_HF_INFERENCE=false

# ── Langfuse observability (optional but recommended) ────────────────────────
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Evaluation ───────────────────────────────────────────────────────────────
FAITHFULNESS_THRESHOLD=0.7
